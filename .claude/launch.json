{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "homevault-web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "5757"],
      "port": 5757
    },
    {
      "name": "homevault-web-release",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "5758", "--directory", "build/web"],
      "port": 5758
    }
  ]
}
